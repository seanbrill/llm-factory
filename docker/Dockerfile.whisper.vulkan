# syntax=docker/dockerfile:1
#
# Speech-to-text runtime (whisper.cpp), Vulkan/GPU. Mirrors Dockerfile.vulkan's
# patched-Venus-Mesa runtime so it GPU-accelerates inside the macOS Podman/krunkit
# machine. whisper-server transcribes audio via POST /inference (multipart
# form-data; the audio file in the `file` field). The baked model is a whisper
# ggml model (staged as model.gguf — the name is cosmetic, the content is what
# whisper-server reads).
#
# Run it (macOS Podman libkrun/krunkit machine):
#   podman run --device /dev/dri --security-opt label=disable -p 8080:8080 <image>

# ----------------------------------------------------------------------------
# Stage 1: compile whisper.cpp's server with the Vulkan backend (Fedora 44)
# ----------------------------------------------------------------------------
FROM quay.io/fedora/fedora:44 AS builder
ARG WHISPER_CPP_REF=master
RUN dnf install -y \
        gcc gcc-c++ cmake git ca-certificates \
        vulkan-headers vulkan-loader-devel vulkan-tools \
        spirv-tools spirv-headers-devel glslc glslang \
    && dnf clean all
WORKDIR /src
RUN git clone --depth 1 --branch "${WHISPER_CPP_REF}" https://github.com/ggml-org/whisper.cpp.git
WORKDIR /src/whisper.cpp
RUN cmake -B build \
        -DCMAKE_BUILD_TYPE=Release \
        -DGGML_NATIVE=OFF \
        -DGGML_VULKAN=ON \
        -DWHISPER_BUILD_SERVER=ON \
    && cmake --build build --config Release -j "$(nproc)" --target whisper-server

# ----------------------------------------------------------------------------
# Stage 2: Vulkan runtime (Fedora 44 + PATCHED Venus Mesa) + baked model
# ----------------------------------------------------------------------------
FROM quay.io/fedora/fedora:44 AS runtime
# Passed uniformly by the builder; whisper doesn't use them but declaring avoids
# "unused ARG" build warnings.
ARG INJECT_MODE=missing
ARG MODALITY=audio-stt
ARG CTX_SIZE=0
ARG MESA_VULKAN_VERSION=25.3.6-102.fc44
RUN dnf install -y dnf-plugins-core 'dnf-command(copr)' 'dnf-command(versionlock)' \
    && dnf copr enable -y slp/mesa-libkrun-vulkan \
    && dnf install -y \
        mesa-vulkan-drivers-${MESA_VULKAN_VERSION} \
        vulkan-loader vulkan-tools libgomp curl ca-certificates \
    && dnf versionlock add mesa-vulkan-drivers \
    && dnf clean all \
    && useradd --system --uid 10001 whisper \
    && mkdir -p /models

COPY --from=builder /src/whisper.cpp/build/bin/whisper-server /usr/local/bin/whisper-server
COPY model.gguf /models/model.gguf

ENV PORT=8080 \
    XDG_RUNTIME_DIR=/tmp
EXPOSE 8080
USER whisper
ENTRYPOINT ["/usr/local/bin/whisper-server", "-m", "/models/model.gguf", \
            "--host", "0.0.0.0", "--port", "8080"]
