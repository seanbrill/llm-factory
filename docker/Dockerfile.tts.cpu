# syntax=docker/dockerfile:1
#
# Text-to-speech runtime (Piper, CPU). Self-contained: bakes a default English
# voice and serves an OpenAI-style POST /v1/audio/speech that returns WAV audio.
# Piper is CPU-only (~10x realtime) so there's no GPU plumbing. There's no GGUF
# to download — the builder special-cases the "tts" family (skips model staging),
# and this image fetches its voice at build time.

FROM ubuntu:24.04
# Passed uniformly by the builder; declared to avoid "unused ARG" warnings.
ARG INJECT_MODE=missing
ARG MODALITY=tts
ARG CTX_SIZE=0
ARG PIPER_VOICE_BASE=https://huggingface.co/rhasspy/piper-voices/resolve/main/en/en_US/lessac/medium

RUN apt-get update && apt-get install -y --no-install-recommends \
        python3 python3-pip curl ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && pip3 install --break-system-packages --no-cache-dir piper-tts \
    && mkdir -p /voices /app \
    && curl -fsSL -o /voices/voice.onnx      "${PIPER_VOICE_BASE}/en_US-lessac-medium.onnx?download=true" \
    && curl -fsSL -o /voices/voice.onnx.json "${PIPER_VOICE_BASE}/en_US-lessac-medium.onnx.json?download=true"

# Tiny stdlib HTTP wrapper: OpenAI-style /v1/audio/speech -> WAV. Loads the voice
# once at startup. Accepts {"input": "..."} (OpenAI) or {"text": "..."}.
RUN cat > /app/tts_server.py <<'PY'
import io, json, wave
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from piper import PiperVoice

VOICE = PiperVoice.load("/voices/voice.onnx")

class H(BaseHTTPRequestHandler):
    def _send(self, code, ctype, body):
        self.send_response(code)
        self.send_header("Content-Type", ctype)
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)
    def log_message(self, *a):  # quiet default logging
        pass
    def do_GET(self):
        if self.path == "/health":
            self._send(200, "application/json", b'{"status":"ok"}')
        else:
            self._send(404, "text/plain", b"not found")
    def do_POST(self):
        if self.path not in ("/v1/audio/speech", "/api/tts"):
            self._send(404, "text/plain", b"not found"); return
        try:
            n = int(self.headers.get("Content-Length", 0))
            req = json.loads(self.rfile.read(n) or b"{}")
            text = (req.get("input") or req.get("text") or "").strip()
        except Exception:
            self._send(400, "text/plain", b"bad request"); return
        if not text:
            self._send(400, "text/plain", b"missing 'input'"); return
        buf = io.BytesIO()
        with wave.open(buf, "wb") as wf:
            VOICE.synthesize_wav(text, wf)
        self._send(200, "audio/wav", buf.getvalue())

print("[tts] piper ready on :8080 (/v1/audio/speech)", flush=True)
ThreadingHTTPServer(("0.0.0.0", 8080), H).serve_forever()
PY

ENV PORT=8080
EXPOSE 8080
ENTRYPOINT ["python3", "/app/tts_server.py"]
