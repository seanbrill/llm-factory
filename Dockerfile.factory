# syntax=docker/dockerfile:1
#
# Dockerizes the factory ITSELF so it runs on any machine that has Docker.
#
# The factory builds and runs *model* images by talking to the host's Docker
# daemon (Docker-out-of-Docker): run it with the host docker socket mounted
# (`-v /var/run/docker.sock:/var/run/docker.sock`). Use start.{ps1,sh}.
#
# At runtime the factory reads two things from disk (besides the embedded UI):
#   docker/Dockerfile.{cpu,cuda,vulkan}   and   cmd/llmgate/main.go
# so both are copied into the image.
#
# The image also bundles a Podman *remote* client so the factory can drive a host
# Podman machine in addition to Docker — that's the macOS GPU path (a libkrun
# machine paravirtualizes Metal into a Vulkan container). start.{sh,ps1} mount the
# host Podman socket and set CONTAINER_HOST when a machine is present.

# ----------------------------------------------------------------------------
# Stage 1: compile the factory (static, stdlib-only -> runs on Alpine)
# ----------------------------------------------------------------------------
FROM golang:1.22-bookworm AS build
WORKDIR /src
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags "-s -w" -o /factory ./cmd/builder

# ----------------------------------------------------------------------------
# Stage 2: docker CLI base (talks to the mounted host daemon)
# ----------------------------------------------------------------------------
FROM docker:27-cli
WORKDIR /app

# Podman remote client (named `podman` on PATH so the factory's engine selector
# can shell out to it). Prefer the lean podman-remote subpackage; fall back to the
# full podman package if the remote-only one isn't in the repo.
RUN (apk add --no-cache podman-remote && ln -sf "$(command -v podman-remote)" /usr/local/bin/podman) \
    || apk add --no-cache podman

COPY --from=build /factory      /usr/local/bin/factory
COPY docker/                    /app/docker/
COPY cmd/llmgate/               /app/cmd/llmgate/

# host.docker.internal lets the in-UI "Test" reach model containers' published
# ports on the host. (start.{ps1,sh} adds --add-host for Linux hosts.)
ENV MODEL_HOST=host.docker.internal

EXPOSE 8799
ENTRYPOINT ["factory", "-dir", "/app", "-addr", "0.0.0.0:8799", "-open=false"]
