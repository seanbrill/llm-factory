# syntax=docker/dockerfile:1
#
# Dockerizes the factory ITSELF so it runs on any machine that has Docker.
#
# The factory builds and runs *model* images by talking to the host's Docker
# daemon (Docker-out-of-Docker): run it with the host docker socket mounted
# (`-v /var/run/docker.sock:/var/run/docker.sock`). Use start.{ps1,sh}.
#
# At runtime the factory reads two things from disk (besides the embedded UI):
#   docker/Dockerfile.{cpu,cuda,vulkan}   and   cmd/llmgate/main.go
# so both are copied into the image.
#
# The image also bundles a Podman *remote* client so the factory can drive a host
# Podman machine in addition to Docker — that's the macOS GPU path (a libkrun
# machine paravirtualizes Metal into a Vulkan container). start.{sh,ps1} mount the
# host Podman socket and set CONTAINER_HOST when a machine is present.

# ----------------------------------------------------------------------------
# Stage 1: compile the factory (static, stdlib-only -> runs on Alpine)
# ----------------------------------------------------------------------------
FROM golang:1.22-bookworm AS build
WORKDIR /src
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags "-s -w" -o /factory ./cmd/builder

# ----------------------------------------------------------------------------
# Stage 2: docker CLI base (talks to the mounted host daemon)
# ----------------------------------------------------------------------------
FROM docker:27-cli
WORKDIR /app

# Podman remote client (named `podman` on PATH so the factory's engine selector
# can shell out to it). We install the official statically-linked release pinned
# to PODMAN_VERSION rather than Alpine's `podman-remote` package: the Alpine build
# lags well behind (5.3.x) and chokes when streaming a large model layer to a 5.8
# host machine — a multi-GB `COPY` drops with "server quit: unexpected EOF". The
# static binary needs no musl/glibc shims and runs as-is on this base. Pinned URL
# + SHA-256 verification keeps the supply chain reproducible and tamper-evident.
# Bump PODMAN_VERSION (and both checksums from the release `shasums`) to track the
# host Podman; the client should match the machine's server major.minor.
ARG PODMAN_VERSION=5.8.4
ARG TARGETARCH
RUN set -eux; \
    case "$TARGETARCH" in \
      arm64) sha=6c7184d158e5d54e5a324ba6a6da264862bd5baa61d992f65fe855db51406bea ;; \
      amd64) sha=3d2a1a45f668fe5c240deb8df83d9e2e415429fb91f8a7442985a636edf33654 ;; \
      *) echo "unsupported TARGETARCH: $TARGETARCH" >&2; exit 1 ;; \
    esac; \
    wget -qO /tmp/podman-remote.tgz \
      "https://github.com/containers/podman/releases/download/v${PODMAN_VERSION}/podman-remote-static-linux_${TARGETARCH}.tar.gz"; \
    echo "${sha}  /tmp/podman-remote.tgz" | sha256sum -c -; \
    tar -xzf /tmp/podman-remote.tgz -C /tmp; \
    install -m 0755 "/tmp/bin/podman-remote-static-linux_${TARGETARCH}" /usr/local/bin/podman; \
    rm -rf /tmp/podman-remote.tgz /tmp/bin; \
    podman --version

COPY --from=build /factory      /usr/local/bin/factory
COPY docker/                    /app/docker/
COPY cmd/llmgate/               /app/cmd/llmgate/

# host.docker.internal lets the in-UI "Test" reach model containers' published
# ports on the host. (start.{ps1,sh} adds --add-host for Linux hosts.)
ENV MODEL_HOST=host.docker.internal

EXPOSE 8799
HEALTHCHECK --interval=30s --timeout=4s --start-period=10s --retries=3 \
    CMD wget -qO- http://127.0.0.1:8799/healthz >/dev/null 2>&1 || exit 1
ENTRYPOINT ["factory", "-dir", "/app", "-addr", "0.0.0.0:8799", "-open=false"]
