# Keep the factory build context small: the image only needs Go source +
# docker/ + cmd/llmgate/. Weights, exported tars, and temp contexts are mounted
# from the host at runtime, not baked into the factory image.
.git
.gitignore
models/
images/
config/
media/
.build/
*.gguf
*.tar
local-llm
local-llm.exe
*.log
README.md
docs/
deploy/
# New frontend source (Svelte/Vite): built separately by `vite`; the factory image
# embeds the OUTPUT in internal/server/web, never this source or its node_modules.
ui/
**/node_modules/
**/dist/
