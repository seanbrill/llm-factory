# Downloaded GGUF weights and exported image tarballs — large, regenerable.
/models/*
!/models/.gitkeep
/images/*
!/images/.gitkeep

# Temp docker build contexts.
/.build/

# Built tool binary.
/local-llm
/local-llm.exe

# Note: config/models.json is committed (tracked) so the catalog syncs across
# machines. It is still seeded from the embedded default on a fresh checkout.
# Runtime build-duration stats (used for the build ETA).
/config/build-stats.json
# Generated reverse-proxy config.
/config/Caddyfile

# Agent scratch/temp files.
/scratchpad/
